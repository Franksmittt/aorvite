# Copy to .env.local for local dev, and set the same keys in Vercel → Settings → Environment Variables

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=aor-vite
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional kill switch — set to true to pause Firebase sync (photos/jobs stay
# on the device only). Leave empty/false for normal cloud sync.
VITE_LOCAL_FIRST_MODE=
